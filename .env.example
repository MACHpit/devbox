# MACHpit DevBox - Environment Configuration
# Copy this to .env and fill in your values
# Load with: source .env

# ── AWS ───────────────────────────────────────────────────────────────────────
export AWS_PROFILE=machpit
export AWS_REGION=us-east-1

# ── DevBox Infrastructure (set after MACHpit AWS account is ready) ────────────
export DEVBOX_S3_BUCKET=machpit-devbox
export DEVBOX_KEYPAIR=machpit-devbox
export DEVBOX_SUBNET=subnet-xxxxxxxxxxxxxxxxx
export DEVBOX_VPC=vpc-xxxxxxxxxxxxxxxxx
export DEVBOX_IDLE_MINUTES=120

# ── Secrets Manager key name (not the PAT itself - never put PAT here) ────────
export DEVBOX_PAT_SECRET=machpit/github-pat
