#!/bin/bash
# mach - MACHpit DevBox on-box helper
# Lives at /usr/local/bin/mach on every worker
set -euo pipefail

REPO_DIR="${MACH_REPO_DIR:-/opt/devbox/workspace/repo}"
S3_BUCKET="${DEVBOX_S3_BUCKET:-machpit-devbox}"
STACK_NAME="${STACK_NAME:-}"
REGION="${AWS_REGION:-us-east-1}"

usage() {
  cat <<EOF
mach - MACHpit DevBox helper

  mach branch <name>       create and checkout a new branch
  mach test                run this repo's test suite (.devbox.yml test cmd)
  mach done "<message>"    commit all changes, push, open PR
  mach status              show git status + current branch
  mach nuke                self-destruct this worker
  mach log "<message>"     append a message to the worker log in S3
  mach env                 show current devbox environment
EOF
}

cmd_branch() {
  [ -z "${1:-}" ] && { echo "Usage: mach branch <name>"; exit 1; }
  cd "$REPO_DIR"
  git checkout -b "$1"
  echo "On branch: $1"
}

cmd_test() {
  cd "$REPO_DIR"
  if [ -f .devbox.yml ]; then
    TEST_CMD=$(python3 -c "
import yaml
d = yaml.safe_load(open('.devbox.yml'))
print(d.get('test',''))
" 2>/dev/null || echo "")
    if [ -n "$TEST_CMD" ]; then
      echo "Running: $TEST_CMD"
      eval "$TEST_CMD"
    else
      echo "No test command in .devbox.yml"
    fi
  else
    echo "No .devbox.yml found - nothing to run"
  fi
}

cmd_done() {
  MSG="${1:-devbox: automated commit}"
  cd "$REPO_DIR"
  BRANCH=$(git rev-parse --abbrev-ref HEAD)
  git add -A
  git commit -m "$MSG" || echo "Nothing to commit"
  git push origin "$BRANCH"
  gh pr create \
    --title "devbox: $BRANCH" \
    --body "$MSG" \
    --base main || echo "PR already exists or branch is not ahead of main"
  echo "Done. PR opened for branch: $BRANCH"
}

cmd_status() {
  cd "$REPO_DIR"
  echo "Branch : $(git rev-parse --abbrev-ref HEAD)"
  echo "Remote : $(git remote get-url origin)"
  echo "Worker : ${STACK_NAME:-unknown}"
  echo "---"
  git status --short
}

cmd_nuke() {
  echo "Self-destructing worker: $STACK_NAME"
  aws cloudformation delete-stack \
    --stack-name "$STACK_NAME" \
    --region "$REGION" || true
  echo "Stack deletion initiated."
}

cmd_log() {
  MSG="${1:-}"
  TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  echo "[$TIMESTAMP] $MSG" >> /var/log/devbox-bootstrap.log
  aws s3 cp /var/log/devbox-bootstrap.log \
    "s3://${S3_BUCKET}/devbox/logs/${STACK_NAME}/bootstrap.log" \
    --quiet || true
}

cmd_env() {
  echo "STACK_NAME  = ${STACK_NAME:-not set}"
  echo "S3_BUCKET   = ${S3_BUCKET}"
  echo "REGION      = ${REGION}"
  echo "REPO_DIR    = ${REPO_DIR}"
  echo "BRANCH      = $(cd $REPO_DIR && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
}

case "${1:-}" in
  branch) cmd_branch "${2:-}" ;;
  test)   cmd_test ;;
  done)   cmd_done "${2:-}" ;;
  status) cmd_status ;;
  nuke)   cmd_nuke ;;
  log)    cmd_log "${2:-}" ;;
  env)    cmd_env ;;
  *)      usage ;;
esac
