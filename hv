#!/bin/bash
# hv - DevBox agent helper
# Lives at /usr/local/bin/hv on every worker
set -euo pipefail

REPO_DIR="/opt/devbox/workspace/repo"
S3_BUCKET="${DEVBOX_S3_BUCKET:-hackerverse-agents}"
STACK_NAME="${STACK_NAME:-}"
REGION="${AWS_REGION:-us-east-1}"

usage() {
  cat <<EOF
hv - MACHpit DevBox helper

  hv branch <name>       create and checkout a new branch
  hv test                run this repo's test suite (.devbox.yml test cmd)
  hv done "<message>"    commit all changes, push, open PR
  hv status              show git status + current branch
  hv nuke                self-destruct this worker
  hv log <message>       append a message to the worker log in S3
EOF
}

cmd_branch() {
  cd "$REPO_DIR"
  git checkout -b "$1"
  echo "On branch: $1"
}

cmd_test() {
  cd "$REPO_DIR"
  if [ -f .devbox.yml ]; then
    TEST_CMD=$(python3 -c "
import yaml
d = yaml.safe_load(open('.devbox.yml'))
print(d.get('test',''))
" 2>/dev/null || echo "")
    if [ -n "$TEST_CMD" ]; then
      echo "Running: $TEST_CMD"
      eval "$TEST_CMD"
    else
      echo "No test command in .devbox.yml"
    fi
  else
    echo "No .devbox.yml found - nothing to run"
  fi
}

cmd_done() {
  MSG="${1:-devbox: automated commit}"
  cd "$REPO_DIR"
  BRANCH=$(git rev-parse --abbrev-ref HEAD)
  git add -A
  git commit -m "$MSG" || echo "Nothing to commit"
  git push origin "$BRANCH"
  gh pr create \
    --title "devbox: $BRANCH" \
    --body "$MSG" \
    --base main || echo "PR already exists or branch not ahead of main"
  echo "Done. PR opened for branch: $BRANCH"
}

cmd_status() {
  cd "$REPO_DIR"
  echo "Branch: $(git rev-parse --abbrev-ref HEAD)"
  echo "Remote: $(git remote get-url origin)"
  git status --short
}

cmd_nuke() {
  echo "Self-destructing worker: $STACK_NAME"
  aws cloudformation delete-stack \
    --stack-name "$STACK_NAME" \
    --region "$REGION" || true
  echo "Stack deletion initiated."
}

cmd_log() {
  MSG="${1:-}"
  TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  echo "[$TIMESTAMP] $MSG" >> /var/log/devbox-bootstrap.log
  aws s3 cp /var/log/devbox-bootstrap.log \
    "s3://${S3_BUCKET}/devbox/logs/${STACK_NAME}/bootstrap.log" \
    --quiet || true
}

case "${1:-}" in
  branch)  cmd_branch "${2:-}" ;;
  test)    cmd_test ;;
  done)    cmd_done "${2:-}" ;;
  status)  cmd_status ;;
  nuke)    cmd_nuke ;;
  log)     cmd_log "${2:-}" ;;
  *)       usage ;;
esac
